{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "okrapk",
  "version": "0.1.4",
  "identifier": "app.okrapk",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "OKRA",
        "width": 320,
        "height": 400,
        "resizable": false,
        "maximizable": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk5N0NFOEM2NzFBQTRFRDcKUldUWFRxcHh4dWg4bWVjQm84Y2NTa01hY0ora1VqM2dKNkFUZjZSNXhCQTRHUjRHWGxieWZ6Z0QK",
      "endpoints": [
        "https://github.com/am25-labs/okrapk/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "assets/installer-header.bmp",
        "sidebarImage": "assets/installer-sidebar.bmp"
      }
    }
  }
}
